# ============================================
# Kaspi Bot - Настройки окружения
# ============================================
# Скопируйте этот файл в .env и заполните значения:
#   cp .env.example .env
#   nano .env
# ============================================

# Kaspi Merchant API токен (получить в кабинете продавца)
KASPI_API_TOKEN=your_kaspi_api_token_here

# Telegram Bot токен (получить через @BotFather)
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# Интервал проверки заказов (в секундах, по умолчанию 120 = 2 минуты)
CHECK_INTERVAL=120
